import { useState } from 'react';
import { useTheme } from '@/shared/theme/ThemeProvider';
import { Icon } from '@/shared/ui';
import { useJournalSession } from './JournalSession';

export interface JournalLockProps {
  uid: string;
  /** Appelé après création du PIN pour persister le verifier dans AppData. */
  onPinCreated: (verifier: { iv: string; ct: string }) => void;
}

/**
 * Écran de verrouillage du journal.
 *  - Si aucun PIN : mode création (double saisie + avertissement).
 *  - Sinon : mode déverrouillage.
 */
export function JournalLock({ uid, onPinCreated }: JournalLockProps) {
  const { C, dawn, glowShadow } = useTheme();
  const { hasPin, createPin, unlock } = useJournalSession();

  const [pin, setPin] = useState('');
  const [pin2, setPin2] = useState('');
  const [err, setErr] = useState('');
  const [busy, setBusy] = useState(false);

  const creating = !hasPin;

  const submit = async () => {
    setErr('');
    if (pin.length < 4) {
      setErr('Le code doit faire au moins 4 caractères.');
      return;
    }
    if (creating && pin !== pin2) {
      setErr('Les deux codes ne correspondent pas.');
      return;
    }
    setBusy(true);
    try {
      if (creating) {
        const verifier = await createPin(pin, uid);
        onPinCreated(verifier);
      } else {
        const ok = await unlock(pin, uid);
        if (!ok) {
          setErr('Code incorrect.');
          setPin('');
        }
      }
    } catch {
      setErr('Une erreur est survenue.');
    } finally {
      setBusy(false);
    }
  };

  return (
    <div
      className="flex-1 flex flex-col items-center justify-center px-8"
      style={{ color: C.text }}
    >
      <div
        className="w-16 h-16 rounded-full flex items-center justify-center mb-5"
        style={{ background: C.surf }}
      >
        <Icon name="user" size={28} color={C.gold} />
      </div>

      <h2 className="text-xl font-bold mb-2 text-center">
        {creating ? 'Protéger ton journal' : 'Journal verrouillé'}
      </h2>
      <p className="text-sm text-center mb-6" style={{ color: C.dim, maxWidth: 320 }}>
        {creating
          ? 'Choisis un code secret. Tes entrées seront chiffrées : personne ne pourra les lire sans ce code.'
          : 'Saisis ton code pour déchiffrer et lire tes entrées.'}
      </p>

      <input
        type="password"
        inputMode="numeric"
        autoFocus
        value={pin}
        onChange={(e) => setPin(e.target.value)}
        onKeyDown={(e) => e.key === 'Enter' && !creating && submit()}
        placeholder="Code secret"
        className="w-full max-w-xs px-4 py-3 rounded-xl outline-none text-center mb-3"
        style={{ background: C.surf, color: C.text, border: `1px solid ${C.line}`, fontSize: 18, letterSpacing: 4 }}
      />

      {creating && (
        <input
          type="password"
          inputMode="numeric"
          value={pin2}
          onChange={(e) => setPin2(e.target.value)}
          onKeyDown={(e) => e.key === 'Enter' && submit()}
          placeholder="Confirme le code"
          className="w-full max-w-xs px-4 py-3 rounded-xl outline-none text-center mb-3"
          style={{ background: C.surf, color: C.text, border: `1px solid ${C.line}`, fontSize: 18, letterSpacing: 4 }}
        />
      )}

      {err && (
        <div className="text-sm mb-3 text-center" style={{ color: C.ember }}>
          {err}
        </div>
      )}

      {creating && (
        <div
          className="w-full max-w-xs rounded-xl px-4 py-3 mb-4 text-xs"
          style={{ background: C.surf, border: `1px solid ${C.ember}`, color: C.ember, lineHeight: 1.5 }}
        >
          ⚠️ Important : ce code n’est stocké nulle part. Si tu l’oublies, tes
          entrées seront <strong>définitivement irrécupérables</strong>. Aucune
          réinitialisation n’est possible.
        </div>
      )}

      <button
        onClick={submit}
        disabled={busy}
        className="w-full max-w-xs py-3 rounded-xl font-semibold"
        style={{ background: dawn, color: '#1A1206', boxShadow: glowShadow(), opacity: busy ? 0.6 : 1 }}
      >
        {busy ? '…' : creating ? 'Activer le journal' : 'Déverrouiller'}
      </button>
    </div>
  );
}
